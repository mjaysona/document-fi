{
  "name": "pv3-boilerplate",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "ci": "payload migrate && pnpm build",
    "dev": "cross-env NODE_OPTIONS=\"${NODE_OPTIONS} --no-deprecation\" next dev",
    "devsafe": "rm -rf .next && pnpm dev",
    "generate:importmap": "payload generate:importmap",
    "generate:schema": "cross-env NODE_OPTIONS=--no-deprecation payload-graphql generate:schema",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "payload",
    "seed": "payload run ./src/scripts/seed.ts -- standalone",
    "assign": "payload run ./src/scripts/assign-roles.ts -- standalone",
    "standalone-script": "payload run ./src/scripts/standalone-script.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "update:payload": "pnpm up payload@latest @payloadcms/*@latest"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  },
  "dependencies": {
    "@innovixx/payload-color-picker-field": "^2.0.1",
    "@mantine/core": "^8.1.0",
    "@mantine/form": "^8.1.0",
    "@mantine/hooks": "^8.1.0",
    "@nouance/payload-better-fields-plugin": "^2.0.2",
    "@payloadcms/admin-bar": "3.80.0",
    "@payloadcms/db-mongodb": "3.80.0",
    "@payloadcms/db-postgres": "3.80.0",
    "@payloadcms/live-preview-react": "3.80.0",
    "@payloadcms/next": "3.80.0",
    "@payloadcms/plugin-nested-docs": "3.80.0",
    "@payloadcms/richtext-lexical": "3.80.0",
    "@payloadcms/storage-s3": "3.80.0",
    "@payloadcms/ui": "3.80.0",
    "@react-email/components": "^0.1.0",
    "@tanstack/react-query": "^5.83.0",
    "better-auth": "^1.2.12",
    "cross-env": "^7.0.3",
    "graphql": "^16.8.2",
    "inquirer": "^12.6.3",
    "lodash": "^4.17.21",
    "lucide-react": "^0.487.0",
    "mongodb": "^6.17.0",
    "next": "^16.2.1",
    "payload": "3.80.0",
    "qs-esm": "^7.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.51.3",
    "resend": "^4.6.0",
    "sharp": "0.32.6"
  },
  "devDependencies": {
    "@payloadcms/graphql": "3.80.0",
    "@tanstack/eslint-plugin-query": "^5.81.2",
    "@types/node": "^20.14.9",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "eslint": "^9.22.0",
    "eslint-config-next": "15.0.0-canary.173",
    "postcss": "^8.5.5",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "5.5.4"
  }
}
